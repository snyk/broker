# Snyk (https://snyk.io) policy file, patches or ignores known vulnerabilities.
version: v1.25.1
# ignores vulnerabilities until expiry date; change duration by modifying expiry date
ignore:
  SNYK-JS-BRACEEXPANSION-17706650:
    - '*':
        reason: >-
          Fix is backported to brace-expansion 1.1.16 (CVE-2026-13149
          mitigations present); Snyk only recognises 5.0.7 as fixed. minimatch
          3.x requires the 1.x CommonJS function export, so 5.x cannot be used.
        created: 2026-07-13T00:00:00.000Z
        expires: 2026-10-13T00:00:00.000Z
patch: {}
exclude:
  global:
    - lib/hybrid-sdk/server/routesHandlers/serviceHandler.ts
